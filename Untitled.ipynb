   "source": [
    "import numpy as np\n",
    "data = np.memmap('data/shakespeare_char/train.bin',\n",
    "dtype=np.uint16, mode='r')\n",
    "for frac in [0.10, 0.25, 0.50, 1.00]:\n",
    "    subset = data[:int(len(data) * frac)]\n",
    "    subset.tofile(f'data/shakespeare_char/train_{int(frac*100)}.bin')"
   ]
